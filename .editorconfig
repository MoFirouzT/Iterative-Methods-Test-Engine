root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Julia default: 4-space indentation. Applies to scripts, experiments, tests,
# and root-level scripts (reproduce.jl).
[*.jl]
indent_style = space
indent_size = 4

# Engine + content (library code) is tab-indented — overrides the .jl default.
# This is the established convention: src/, algorithms/, and problems/ use tabs;
# experiments/ and test/ use spaces.
[{src,algorithms,problems}/**.jl]
indent_style = tab

[*.{toml,yml,yaml,json}]
indent_style = space
indent_size = 2
